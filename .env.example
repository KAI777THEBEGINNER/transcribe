# Copy to .env and fill in your own values.
#
# HF_TOKEN: get one at https://huggingface.co/settings/tokens (read access).
#           Then accept the gated-model agreement on:
#           - https://huggingface.co/pyannote/segmentation-3.0
#           - https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_xxx_replace_me

# Where models live. Use any disk with 3GB+ free. External SSD is fine
# (the cache is the only big artifact, transcribe.py re-uses it).
HF_CACHE_DIR=/path/to/hf_cache
TORCH_CACHE_DIR=/path/to/torch_cache

# Optional: HTTP proxy for huggingface.co + download.pytorch.org.
# Leave blank if your network can reach both directly.
PROXY=

# Optional: HF mirror for users in CN. If set, prefetch.py uses this and
# bypasses PROXY for HF traffic (the mirror is in CN, proxy hurts).
# torchaudio downloads still go through PROXY because they live on
# download.pytorch.org (overseas).
HF_MIRROR=
